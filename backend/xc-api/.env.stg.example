SPRING_PROFILES_ACTIVE=stg
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8080

DB_HOST=stg-postgres.example.internal
DB_PORT=5432
DB_NAME=xc_learning_stg
DB_USER=xc_stg_user
DB_PASSWORD=replace_in_deploy_platform
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=4
DB_POOL_CONNECTION_TIMEOUT_MS=30000
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000
DB_POOL_VALIDATION_TIMEOUT_MS=5000
DB_FLYWAY_ENABLED=false
DB_FLYWAY_BASELINE_ON_MIGRATE=false
DB_MIGRATION_LOCATIONS=filesystem:../../database/migrations

REDIS_HOST=stg-redis.example.internal
REDIS_PORT=6379

MINIO_ENDPOINT=https://stg-minio.example.com
MINIO_ACCESS_KEY=replace_in_deploy_platform
MINIO_SECRET_KEY=replace_in_deploy_platform
MINIO_BUCKET=xc-learning-stg
MINIO_CREATE_BUCKET=false

JWT_SECRET=replace_in_deploy_platform
JWT_ISSUER=xc-learning
JWT_EXPIRES_MINUTES=120

CORS_ALLOWED_ORIGIN_PATTERNS=https://stg-admin.example.com,https://stg-web.example.com
CORS_ALLOW_CREDENTIALS=false

FILE_UPLOAD_MAX_SIZE=20MB
FILE_UPLOAD_MAX_REQUEST_SIZE=20MB
MEDIA_STORAGE_TYPE=minio
MEDIA_STORAGE_ROOT=./uploads/media
MEDIA_PUBLIC_URL_PREFIX=/api/media
ASR_ENGINE_NAME=local-asr
ASR_PROVIDER=http
ASR_WORKER_ENABLED=false
ASR_INITIAL_DELAY_MS=5000
ASR_POLL_DELAY_MS=5000
ASR_BATCH_SIZE=5
ASR_SERVICE_URL=
ASR_SERVICE_PATH=/recognize
ASR_MOCK_RECOGNIZED_TEXT=

TASK_EXECUTION_CORE_SIZE=4
TASK_EXECUTION_MAX_SIZE=16
TASK_EXECUTION_QUEUE_CAPACITY=200
TASK_SCHEDULING_POOL_SIZE=4
