SPRING_PROFILES_ACTIVE=stg
SERVER_PORT=8080

DB_HOST=stg-postgres.example.internal
DB_PORT=5432
DB_NAME=xc_learning_stg
DB_USER=xc_stg_user
DB_PASSWORD=replace_in_deploy_platform
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=4
DB_POOL_CONNECTION_TIMEOUT_MS=30000
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000
DB_POOL_VALIDATION_TIMEOUT_MS=5000

REDIS_HOST=stg-redis.example.internal
REDIS_PORT=6379

MINIO_ENDPOINT=https://stg-minio.example.com
MINIO_ACCESS_KEY=replace_in_deploy_platform
MINIO_SECRET_KEY=replace_in_deploy_platform
MINIO_BUCKET=xc-learning-stg

JWT_SECRET=replace_in_deploy_platform
JWT_EXPIRES_MINUTES=120
